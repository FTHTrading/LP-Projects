{
  "name": "sovereign-assets-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Institutional-grade asset-backed token issuer operating system — issuance, compliance, reserves, liquidity, treasury",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "db:push": "pnpm --filter @sov/db db:push",
    "db:generate": "pnpm --filter @sov/db db:generate",
    "db:seed": "pnpm --filter @sov/db db:seed"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
