# Sovereign Assets Platform — Environment Configuration
# Copy to .env.local and fill in real values

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sovereign_assets?schema=public"

# Auth
NEXTAUTH_SECRET="CHANGE_ME_IN_PRODUCTION"
NEXTAUTH_URL="http://localhost:3000"

# Blockchain RPC
ETH_RPC_URL="https://mainnet.infura.io/v3/YOUR_KEY"
POLYGON_RPC_URL="https://polygon-rpc.com"

# Exchange API Keys (market-ops)
# CEX_API_KEY=
# CEX_API_SECRET=

# KYC Provider
# KYC_PROVIDER_KEY=
# KYC_WEBHOOK_SECRET=

# Document Storage
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Redis (optional — caching / queues)
REDIS_URL="redis://localhost:6379"

# Email / Notifications
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
